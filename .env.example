# Madrasah ERP local/runtime config

# Recommended: full Apps Script Web App URL
APPS_SCRIPT_URL=https://script.google.com/macros/s/<DEPLOYMENT_ID>/exec

# Optional legacy fallback (same value as APPS_SCRIPT_URL)
API_BASE_URL=

# Optional fallback if you only want to store deployment id
APPS_SCRIPT_DEPLOYMENT_ID=

# Optional: first-admin bootstrap email
BOOTSTRAP_ADMIN_EMAIL=
